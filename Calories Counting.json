        "jsCode": "// Get the raw content string from the previous node\nconst rawContent = $input.item.json.choices[0].message.content;\n\n// Clean the string by removing the Markdown code block wrappers\nconst cleanJsonString = rawContent\n  .replace(/^```json\\n/, '') // Removes the opening ```json\n  .replace(/\\n```$/, '')      // Removes the closing ```\n  .trim();\n\ntry {\n  // Parse the string into a real JSON object\n  const data = JSON.parse(cleanJsonString);\n  \n  // Return the data so n8n can use it in the next steps\n  return {\n    json: data\n  };\n} catch (error) {\n  // If parsing fails, return the error and the string for debugging\n  return {\n    json: {\n      error: \"Failed to parse JSON\",\n      message: error.message,\n      original: cleanJsonString\n    }\n  };\n}"
